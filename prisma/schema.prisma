generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Trucker {
  id         Int      @id @default(autoincrement())
  name       String
  password   String
  points     Int      @default(0)
  company    String

  sponsorId  Int?
  sponsor    Sponsor? @relation(fields: [sponsorId], references: [id])

  cart       Reward[] @relation("TruckerCart")
  records    DrivingReport[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Sponsor {
  id         Int               @id @default(autoincrement())
  name       String
  password   String
  truckers   Trucker[]

  rewards    Reward[]

  /// New relation: all the item-IDs this sponsor has added
  catalog    SponsorCatalog[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Reward {
  id         Int      @id @default(autoincrement())
  name       String
  price      Int
  sponsorId  Int?
  sponsor    Sponsor? @relation(fields: [sponsorId], references: [id])

  truckers   Trucker[] @relation("TruckerCart")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DrivingReport {
  id         Int      @id @default(autoincrement())
  miles      Int
  minutes    Int
  trips      Int
  truckerId  Int
  trucker    Trucker  @relation(fields: [truckerId], references: [id])

  createdAt  DateTime @default(now())
}

/// New pivot table for the sponsor’s catalog of eBay item-IDs
model SponsorCatalog {
  id         Int     @id @default(autoincrement())
  sponsor    Sponsor @relation(fields: [sponsorId], references: [id])
  sponsorId  Int
  itemId     String

  @@unique([sponsorId, itemId])
}

